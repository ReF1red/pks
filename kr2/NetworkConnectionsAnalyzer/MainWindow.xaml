<Window x:Class="NetworkConnectionsAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Анализатор сетевых подключений"
        Height="700"
        Width="1000"
        MinHeight="600"
        MinWidth="900">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="3*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <GroupBox Header="Сетевые интерфейсы" Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
            <ListBox x:Name="InterfacesListBox"
                     DisplayMemberPath="DisplayName"
                     SelectionChanged="InterfacesListBox_SelectionChanged" />
        </GroupBox>

        <GroupBox Header="Информация о выбранном интерфейсе" Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
            <TextBox x:Name="InterfaceDetailsTextBox"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" />
        </GroupBox>

        <GroupBox Header="Проверка URL / URI" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="UrlTextBox" Margin="0,0,8,0" VerticalContentAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Анализировать"
                        Width="130"
                        Click="AnalyzeUrlButton_Click" />
            </Grid>
        </GroupBox>

        <GroupBox Header="Результаты анализа" Grid.Row="2" Grid.Column="0" Margin="0,0,8,0">
            <TextBox x:Name="OutputTextBox"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto" />
        </GroupBox>

        <GroupBox Header="История URL" Grid.Row="2" Grid.Column="1" Margin="8,0,0,0">
            <DockPanel Margin="8">
                <Button DockPanel.Dock="Bottom"
                        Margin="0,8,0,0"
                        Height="28"
                        Content="Очистить историю"
                        Click="ClearHistoryButton_Click" />
                <ListBox x:Name="HistoryListBox" SelectionChanged="HistoryListBox_SelectionChanged" />
            </DockPanel>
        </GroupBox>
    </Grid>
</Window>
